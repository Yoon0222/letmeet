{
  "expo": {
    "name": "피넛",
    "slug": "pickleball",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pickleball",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.pickle.app"
    },
    "android": {
      "package": "com.pickle.app",
      "adaptiveIcon": {
        "backgroundColor": "#12B981",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBFCFB",
          "image": "./assets/images/splash-peanut.png",
          "imageWidth": 140,
          "android": {
            "image": "./assets/images/splash-peanut.png",
            "imageWidth": 140
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필 사진을 올리기 위해 사진 접근 권한이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f6baa6d2-506e-487e-a65d-fa041c68e960"
      }
    }
  }
}
