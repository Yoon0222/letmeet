# Supabase 프로젝트 설정값 (Dashboard → Project Settings → API)
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워 넣으세요.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 결제 provider: mock(개발용 자동성공) | toss(실 토스페이먼츠)
EXPO_PUBLIC_PAYMENT_PROVIDER=mock
# 결제 리턴/체크아웃 페이지 베이스 (web-admin 배포 주소). 앱이 {BASE}/checkout 을 연다.
EXPO_PUBLIC_PAYMENT_RETURN_BASE_URL=https://pinut.org/payment
# 참고: 토스 클라이언트 키(test_ck_.../live_ck_...)는 web-admin env(NEXT_PUBLIC_TOSS_CLIENT_KEY)에,
#       토스 시크릿 키(test_sk_.../live_sk_...)는 Supabase 시크릿(TOSS_SECRET_KEY)에 둔다. 앱엔 넣지 않음.
